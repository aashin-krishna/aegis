 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Aegis Threat Classifier - Deep Learning Model Comparisons\n",
    "This notebook trains and compares three different deep learning architectures on the balanced payload intrusion dataset:\n",
    "1. **Standard 1D CNN** (Local spatial signature feature extractor)\n",
    "2. **CNN-BiLSTM** (Extracts local signatures and captures sequential temporal dependencies)\n",
    "3. **CNN-BiLSTM-Transformer (BERT-Style)** (Adds self-attention to capture long-range packet contents)\n",
    "\n",
    "### Goals:\n",
    "- Load the balanced datasets `balanced_train.csv` and `balanced_val.csv`.\n",
    "- Train all three models under identical parameters.\n",
    "- Save the best weights for each model to your PC (`models/` folder).\n",
    "- Plot comparative validation accuracy and loss curves.\n",
    "- Generate classification reports and plot side-by-side Confusion Matrices."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import gc\n",
    "import joblib\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch.utils.data import TensorDataset, DataLoader\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Using device: {device}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Preprocessed Balanced Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "TRAIN_PATH = 'data/balanced_train.csv'\n",
    "VAL_PATH = 'data/balanced_val.csv'\n",
    "\n",
    "def load_dataset(csv_path):\n",
    "    payload_cols = [f'payload_byte_{i}' for i in range(1, 1501)]\n",
    "    meta_cols = ['ttl', 'total_len', 't_delta', 'protocol']\n",
    "    \n",
    "    dtypes = {f'payload_byte_{i}': np.uint8 for i in range(1, 1501)}\n",
    "    dtypes['ttl'] = np.uint16\n",
    "    dtypes['total_len'] = np.uint32\n",
    "    dtypes['protocol'] = str\n",
    "    dtypes['t_delta'] = np.float32\n",
    "    dtypes['label'] = str\n",
    "    \n",
    "    chunksize = 100000\n",
    "    payload_list = []\n",
    "    meta_list = []\n",
    "    labels_list = []\n",
    "    \n",
    "    for chunk in pd.read_csv(csv_path, dtype=dtypes, chunksize=chunksize):\n",
    "        payload_list.append(chunk[payload_cols].values)\n",
    "        meta_list.append(chunk[meta_cols])\n",
    "        labels_list.append(chunk['label'].values)\n",
    "        \n",
    "    payloads = np.concatenate(payload_list, axis=0)\n",
    "    meta_df = pd.concat(meta_list, ignore_index=True)\n",
    "    labels = np.concatenate(labels_list, axis=0)\n",
    "    return payloads, meta_df, labels\n",
    "\n",
    "print(\"Loading balanced training set...\")\n",
    "X_train_payload, meta_train_df, y_train_str = load_dataset(TRAIN_PATH)\n",
    "print(\"Loading balanced validation set...\")\n",
    "X_val_payload, meta_val_df, y_val_str = load_dataset(VAL_PATH)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Fit Encoders and Scalers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. Label Encoder\n",
    "label_encoder = LabelEncoder()\n",
    "y_train = label_encoder.fit_transform(y_train_str)\n",
    "y_val = label_encoder.transform(y_val_str)\n",
    "num_classes = len(label_encoder.classes_)\n",
    "\n",
    "# 2. Protocol Encoder\n",
    "protocol_encoder = LabelEncoder()\n",
    "train_protos = meta_train_df['protocol'].astype(str).str.strip().str.lower().fillna('unknown')\n",
    "val_protos = meta_val_df['protocol'].astype(str).str.strip().str.lower().fillna('unknown')\n",
    "\n",
    "all_protos = pd.concat([train_protos, val_protos]).unique()\n",
    "protocol_encoder.fit(all_protos)\n",
    "\n",
    "meta_train_df['protocol_encoded'] = protocol_encoder.transform(train_protos)\n",
    "meta_val_df['protocol_encoded'] = protocol_encoder.transform(val_protos)\n",
    "\n",
    "# 3. Feature Scaling\n",
    "meta_cols = ['ttl', 'total_len', 't_delta', 'protocol_encoded']\n",
    "scaler = StandardScaler()\n",
    "X_train_meta = scaler.fit_transform(meta_train_df[meta_cols].values.astype(np.float32))\n",
    "X_val_meta = scaler.transform(meta_val_df[meta_cols].values.astype(np.float32))\n",
    "\n",
    "print(f\"Dataset processed. Target classes: {list(label_encoder.classes_)}\")\n",
    "\n",
    "del meta_train_df, meta_val_df, train_protos, val_protos\n",
    "gc.collect()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Prepare PyTorch DataLoaders"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "train_dataset = TensorDataset(\n",
    "    torch.tensor(X_train_payload, dtype=torch.uint8),\n",
    "    torch.tensor(X_train_meta, dtype=torch.float32),\n",
    "    torch.tensor(y_train, dtype=torch.long)\n",
    ")\n",
    "val_dataset = TensorDataset(\n",
    "    torch.tensor(X_val_payload, dtype=torch.uint8),\n",
    "    torch.tensor(X_val_meta, dtype=torch.float32),\n",
    "    torch.tensor(y_val, dtype=torch.long)\n",
    ")\n",
    "\n",
    "train_loader = DataLoader(train_dataset, batch_size=128, shuffle=True)\n",
    "val_loader = DataLoader(val_dataset, batch_size=256, shuffle=False)\n",
    "print(f\"Batches in Train: {len(train_loader)} | Val: {len(val_loader)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Define Models & Focal Loss"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FocalLoss(nn.Module):\n",
    "    def __init__(self, alpha=None, gamma=2.0):\n",
    "        super(FocalLoss, self).__init__()\n",
    "        self.alpha = alpha\n",
    "        self.gamma = gamma\n",
    "\n",
    "    def forward(self, inputs, targets):\n",
    "        ce_loss = F.cross_entropy(inputs, targets, reduction='none')\n",
    "        pt = torch.exp(-ce_loss)\n",
    "        focal_loss = ((1 - pt) ** self.gamma) * ce_loss\n",
    "        if self.alpha is not None:\n",
    "            alpha_t = self.alpha[targets]\n",
    "            focal_loss = alpha_t * focal_loss\n",
    "        return focal_loss.mean()\n",
    "\n",
    "# -----------------------------------------------------\n",
    "# Model 1: Standard 1D CNN\n",
    "# -----------------------------------------------------\n",
    "class PayloadCNN(nn.Module):\n",
    "    def __init__(self, num_classes=6):\n",
    "        super(PayloadCNN, self).__init__()\n",
    "        self.embedding = nn.Embedding(256, 32)\n",
    "        self.conv1 = nn.Conv1d(32, 64, kernel_size=7, stride=4, padding=3)\n",
    "        self.relu = nn.ReLU()\n",
    "        self.pool = nn.MaxPool1d(2, 2)\n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(64 * 187 + 4, 64),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(64, num_classes)\n",
    "        )\n",
    "        \n",
    "    def forward(self, payload, metadata):\n",
    "        x = self.embedding(payload.long()).transpose(1, 2)  # (batch, 32, 1500)\n",
    "        x = self.pool(self.relu(self.conv1(x)))             # (batch, 64, 187)\n",
    "        x = x.flatten(1)                                    # (batch, 64 * 187)\n",
    "        combined = torch.cat((x, metadata), dim=1)\n",
    "        return self.fc(combined)\n",
    "\n",
    "# -----------------------------------------------------\n",
    "# Model 2: CNN + BiLSTM\n",
    "# -----------------------------------------------------\n",
    "class PayloadCNNBiLSTM(nn.Module):\n",
    "    def __init__(self, num_classes=6):\n",
    "        super(PayloadCNNBiLSTM, self).__init__()\n",
    "        self.embedding = nn.Embedding(256, 32)\n",
    "        self.conv1 = nn.Conv1d(32, 64, kernel_size=7, stride=4, padding=3)\n",
    "        self.relu = nn.ReLU()\n",
    "        self.pool = nn.MaxPool1d(2, 2)\n",
    "        self.lstm = nn.LSTM(64, 64, num_layers=1, batch_first=True, bidirectional=True)\n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(128 + 4, 64),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(64, num_classes)\n",
    "        )\n",
    "        \n",
    "    def forward(self, payload, metadata):\n",
    "        x = self.embedding(payload.long()).transpose(1, 2)\n",
    "        x = self.pool(self.relu(self.conv1(x))).transpose(1, 2) # (batch, 187, 64)\n",
    "        lstm_out, _ = self.lstm(x)\n",
    "        features = lstm_out[:, -1, :]  # (batch, 128)\n",
    "        combined = torch.cat((features, metadata), dim=1)\n",
    "        return self.fc(combined)\n",
    "\n",
    "# -----------------------------------------------------\n",
    "# Model 3: CNN + BiLSTM + Transformer (BERT-Style)\n",
    "# -----------------------------------------------------\n",
    "class PayloadCNNBiLSTMTransformer(nn.Module):\n",
    "    def __init__(self, num_classes=6):\n",
    "        super(PayloadCNNBiLSTMTransformer, self).__init__()\n",
    "        self.embedding = nn.Embedding(256, 32)\n",
    "        self.conv1 = nn.Conv1d(32, 64, kernel_size=7, stride=4, padding=3)\n",
    "        self.relu = nn.ReLU()\n",
    "        self.pool = nn.MaxPool1d(2, 2)\n",
    "        self.lstm = nn.LSTM(64, 64, num_layers=1, batch_first=True, bidirectional=True)\n",
    "        \n",
    "        encoder_layer = nn.TransformerEncoderLayer(d_model=128, nhead=4, dim_feedforward=128, batch_first=True)\n",
    "        self.transformer = nn.TransformerEncoder(encoder_layer, num_layers=1)\n",
    "        \n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(128 + 4, 64),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(0.3),\n",
    "            nn.Linear(64, num_classes)\n",
    "        )\n",
    "        \n",
    "    def forward(self, payload, metadata):\n",
    "        x = self.embedding(payload.long()).transpose(1, 2)\n",
    "        x = self.pool(self.relu(self.conv1(x))).transpose(1, 2)\n",
    "        lstm_out, _ = self.lstm(x)\n",
    "        trans_out = self.transformer(lstm_out)\n",
    "        features = trans_out[:, -1, :]\n",
    "        combined = torch.cat((features, metadata), dim=1)\n",
    "        return self.fc(combined)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Training Engine Helper Function with Saving Logic"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_model(model_class, model_name, num_classes, epochs=5, lr=0.001):\n",
    "    model = model_class(num_classes=num_classes).to(device)\n",
    "    criterion = FocalLoss(gamma=2.0)  # Since classes are balanced, uniform alpha works\n",
    "    optimizer = torch.optim.Adam(model.parameters(), lr=lr)\n",
    "    \n",
    "    MODEL_DIR = 'models'\n",
    "    os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "    best_val_acc = 0.0\n",
    "    \n",
    "    history = {'train_loss': [], 'train_acc': [], 'val_loss': [], 'val_acc': []}\n",
    "    \n",
    "    for epoch in range(epochs):\n",
    "        model.train()\n",
    "        train_loss, train_correct, train_total = 0.0, 0, 0\n",
    "        for payloads, metas, labels in train_loader:\n",
    "            payloads, metas, labels = payloads.to(device), metas.to(device), labels.to(device)\n",
    "            \n",
    "            optimizer.zero_grad()\n",
    "            outputs = model(payloads, metas)\n",
    "            loss = criterion(outputs, labels)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            \n",
    "            train_loss += loss.item() * payloads.size(0)\n",
    "            _, predicted = outputs.max(1)\n",
    "            train_total += labels.size(0)\n",
    "            train_correct += predicted.eq(labels).sum().item()\n",
    "            \n",
    "        # Validation\n",
    "        model.eval()\n",
    "        val_loss, val_correct, val_total = 0.0, 0, 0\n",
    "        with torch.no_grad():\n",
    "            for payloads, metas, labels in val_loader:\n",
    "                payloads, metas, labels = payloads.to(device), metas.to(device), labels.to(device)\n",
                outputs = model(payloads, metas)\n",
                loss = criterion(outputs, labels)\n",
                \n",
                val_loss += loss.item() * payloads.size(0)\n",
                _, predicted = outputs.max(1)\n",
                val_total += labels.size(0)\n",
                val_correct += predicted.eq(labels).sum().item()\n",
                \n",
        t_loss = train_loss / train_total\n",
        t_acc = train_correct / train_total\n",
        v_loss = val_loss / val_total\n",
        v_acc = val_correct / val_total\n",
        \n",
        history['train_loss'].append(t_loss)\n",
        history['train_acc'].append(t_acc)\n",
        history['val_loss'].append(v_loss)\n",
        history['val_acc'].append(v_acc)\n",
        \n",
        print(f\"Epoch {epoch+1:02d} | Train Loss: {t_loss:.4f} | Train Acc: {t_acc:.2%} | Val Loss: {v_loss:.4f} | Val Acc: {v_acc:.2%}\")\n",
        \n",
        # Save best model weights\n",
        if v_acc > best_val_acc:\n",
            best_val_acc = v_acc\n",
            filename = f\"{model_name.lower().replace(' ', '_').replace('-', '_')}.pth\"\n",
            save_path = os.path.join(MODEL_DIR, filename)\n",
            torch.save(model.state_dict(), save_path)\n",
            print(f\"  --> Best weights for {model_name} saved to: {os.path.abspath(save_path)}\")\n",
            \n",
    return model, history"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Train Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "EPOCHS = 5\n",
    "\n",
    "print(\"=== Training Standard 1D CNN ===\")\n",
    "cnn_model, cnn_history = train_model(PayloadCNN, '1D CNN', num_classes, epochs=EPOCHS)\n",
    "\n",
    "print(\"\\n=== Training CNN-BiLSTM ===\")\n",
    "bilstm_model, bilstm_history = train_model(PayloadCNNBiLSTM, 'CNN-BiLSTM', num_classes, epochs=EPOCHS)\n",
    "\n",
    "print(\"\\n=== Training CNN-BiLSTM-Transformer (BERT-style) ===\")\n",
    "transformer_model, transformer_history = train_model(PayloadCNNBiLSTMTransformer, 'CNN-BiLSTM-Transformer', num_classes, epochs=EPOCHS)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Plot Performance Comparisons"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "epochs_range = range(1, EPOCHS + 1)\n",
    "\n",
    "plt.figure(figsize=(14, 5))\n",
    "\n",
    "# Plot Validation Accuracy\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.plot(epochs_range, cnn_history['val_acc'], 'o-', label='1D CNN')\n",
    "plt.plot(epochs_range, bilstm_history['val_acc'], 's-', label='CNN-BiLSTM')\n",
    "plt.plot(epochs_range, transformer_history['val_acc'], 'd-', label='CNN-BiLSTM-Transformer')\n",
    "plt.title('Validation Accuracy Comparison', fontsize=12)\n",
    "plt.xlabel('Epochs')\n",
    "plt.ylabel('Accuracy')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "\n",
    "# Plot Validation Loss\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.plot(epochs_range, cnn_history['val_loss'], 'o-', label='1D CNN')\n",
    "plt.plot(epochs_range, bilstm_history['val_loss'], 's-', label='CNN-BiLSTM')\n",
    "plt.plot(epochs_range, transformer_history['val_loss'], 'd-', label='CNN-BiLSTM-Transformer')\n",
    "plt.title('Validation Loss Comparison', fontsize=12)\n",
    "plt.xlabel('Epochs')\n",
    "plt.ylabel('Loss (Focal Loss)')\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Generate Reports & Confusion Matrices"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate_report(model_class, model_name, loader, name):\n",
    "    model = model_class(num_classes=num_classes).to(device)\n",
    "    MODEL_DIR = 'models'\n",
    "    filename = f\"{model_name.lower().replace(' ', '_').replace('-', '_')}.pth\"\n",
    "    save_path = os.path.join(MODEL_DIR, filename)\n",
    "    if os.path.exists(save_path):\n",
    "        model.load_state_dict(torch.load(save_path, map_location=device, weights_only=True))\n",
    "        print(f\"Best saved weights for {model_name} loaded for evaluation.\")\n",
    "    \n",
    "    model.eval()\n",
    "    all_preds, all_targets = [], []\n",
    "    with torch.no_grad():\n",
    "        for payloads, metas, labels in loader:\n",
    "            payloads, metas = payloads.to(device), metas.to(device)\n",
    "            outputs = model(payloads, metas)\n",
    "            _, predicted = outputs.max(1)\n",
    "            all_preds.extend(predicted.cpu().numpy())\n",
    "            all_targets.extend(labels.numpy())\n",
    "            \n",
    "    print(f\"\\n=========================================\")\n",
    "    print(f\" Classification Report: {name}\")\n",
    "    print(f\"=========================================\")\n",
    "    print(classification_report(all_targets, all_preds, target_names=label_encoder.classes_, zero_division=0))\n",
    "    return confusion_matrix(all_targets, all_preds)\n",
    "\n",
    "cm_cnn = evaluate_report(PayloadCNN, '1D CNN', val_loader, '1D CNN')\n",
    "cm_lstm = evaluate_report(PayloadCNNBiLSTM, 'CNN-BiLSTM', val_loader, 'CNN-BiLSTM')\n",
    "cm_trans = evaluate_report(PayloadCNNBiLSTMTransformer, 'CNN-BiLSTM-Transformer', val_loader, 'CNN-BiLSTM-Transformer')\n",
    "\n",
    "# Plot all three confusion matrices side-by-side\n",
    "fig, axes = plt.subplots(1, 3, figsize=(22, 6))\n",
    "cms = [cm_cnn, cm_lstm, cm_trans]\n",
    "names = ['1D CNN', 'CNN-BiLSTM', 'CNN-BiLSTM-Transformer']\n",
    "\n",
    "for ax, cm, name in zip(axes, cms, names):\n",
    "    sns.heatmap(\n",
    "        cm, \n",
    "        annot=True, \n",
    "        fmt='d', \n",
    "        cmap='Blues', \n",
    "        xticklabels=label_encoder.classes_,\n",
    "        yticklabels=label_encoder.classes_,\n",
    "        ax=ax, \n",
    "        cbar=False\n",
    "    )\n",
    "    ax.set_title(f\"{name} Confusion Matrix\", fontsize=13)\n",
    "    ax.set_ylabel('Actual Label')\n",
    "    ax.set_xlabel('Predicted Label')\n",
    "    ax.set_xticklabels(label_encoder.classes_, rotation=45, ha='right')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
